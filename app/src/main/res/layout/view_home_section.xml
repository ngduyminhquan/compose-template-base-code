<?xml version="1.0" encoding="utf-8"?>
<LinearLayout xmlns:android="http://schemas.android.com/apk/res/android"
    xmlns:tools="http://schemas.android.com/tools"
    android:layout_width="match_parent"
    android:layout_height="wrap_content"
    android:layout_marginTop="@dimen/home_gap_sm"
    android:orientation="vertical">

    <LinearLayout
        android:layout_width="match_parent"
        android:layout_height="wrap_content"
        android:gravity="center_vertical"
        android:orientation="horizontal">

        <TextView
            android:id="@+id/tv_section_title"
            android:layout_width="0dp"
            android:layout_height="wrap_content"
            android:layout_weight="1"
            android:fontFamily="@font/inter_regular"
            android:textColor="@color/home_text_primary"
            android:textSize="@dimen/home_text_13"
            android:textStyle="bold"
            tools:text="Recent (3)" />

        <TextView
            android:id="@+id/tv_view_all"
            android:layout_width="wrap_content"
            android:layout_height="wrap_content"
            android:background="?attr/selectableItemBackground"
            android:fontFamily="@font/inter_regular"
            android:padding="@dimen/home_gap_xs"
            android:text="@string/home_view_all"
            android:textColor="@color/home_text_secondary"
            android:textSize="@dimen/home_text_10" />
    </LinearLayout>

    <HorizontalScrollView
        android:layout_width="match_parent"
        android:layout_height="wrap_content"
        android:scrollbars="none">

        <LinearLayout
            android:id="@+id/video_row"
            android:layout_width="wrap_content"
            android:layout_height="wrap_content"
            android:orientation="horizontal">

            <include layout="@layout/view_home_video_card" />
            <include layout="@layout/view_home_video_card" />
            <include layout="@layout/view_home_video_card" />
        </LinearLayout>
    </HorizontalScrollView>
</LinearLayout>
