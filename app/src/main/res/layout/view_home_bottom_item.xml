<?xml version="1.0" encoding="utf-8"?>
<LinearLayout xmlns:android="http://schemas.android.com/apk/res/android"
    xmlns:tools="http://schemas.android.com/tools"
    android:layout_width="0dp"
    android:layout_height="match_parent"
    android:layout_weight="1"
    android:background="?attr/selectableItemBackground"
    android:gravity="center"
    android:orientation="vertical">

    <ImageView
        android:id="@+id/iv_nav_icon"
        android:layout_width="@dimen/home_icon_md"
        android:layout_height="@dimen/home_icon_md"
        android:contentDescription="@string/home_nav_home"
        tools:src="@drawable/ic_home" />

    <TextView
        android:id="@+id/tv_nav_label"
        android:layout_width="wrap_content"
        android:layout_height="wrap_content"
        android:fontFamily="@font/inter_regular"
        android:textColor="@color/home_text_secondary"
        android:textSize="@dimen/home_text_10"
        tools:text="Home" />
</LinearLayout>
