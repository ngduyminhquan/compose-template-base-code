<?xml version="1.0" encoding="utf-8"?>
<FrameLayout xmlns:android="http://schemas.android.com/apk/res/android"
    xmlns:app="http://schemas.android.com/apk/res-auto"
    android:layout_width="@dimen/home_video_card_width"
    android:layout_height="@dimen/home_video_card_height"
    android:layout_marginEnd="@dimen/home_gap_sm"
    android:clickable="true"
    android:focusable="true">

    <ImageView
        android:id="@+id/iv_video_thumb"
        android:layout_width="match_parent"
        android:layout_height="match_parent"
        android:contentDescription="@string/home_demo_video"
        android:scaleType="centerCrop"
        android:src="@drawable/img_home_banner_2" />

    <View
        android:layout_width="match_parent"
        android:layout_height="match_parent"
        android:background="@drawable/bg_home_video_overlay" />

    <TextView
        android:id="@+id/tv_video_title"
        android:layout_width="wrap_content"
        android:layout_height="wrap_content"
        android:layout_gravity="bottom|start"
        android:layout_margin="@dimen/home_gap_sm"
        android:fontFamily="@font/inter_regular"
        android:text="@string/home_demo_video"
        android:textColor="@color/white"
        android:textSize="@dimen/home_text_11"
        android:textStyle="bold" />

    <ImageButton
        android:id="@+id/btn_video_favorite"
        android:layout_width="@dimen/home_icon_md"
        android:layout_height="@dimen/home_icon_md"
        android:layout_gravity="top|end"
        android:background="?attr/selectableItemBackgroundBorderless"
        android:contentDescription="@string/home_desc_favorite"
        android:padding="@dimen/home_gap_xs"
        android:src="@drawable/ic_favorite"
        app:tint="@color/white" />

    <ImageButton
        android:id="@+id/btn_video_more"
        android:layout_width="@dimen/home_icon_md"
        android:layout_height="@dimen/home_icon_md"
        android:layout_gravity="bottom|end"
        android:background="?attr/selectableItemBackgroundBorderless"
        android:contentDescription="@string/home_desc_more"
        android:padding="@dimen/home_gap_xs"
        android:src="@drawable/ic_channel_option"
        app:tint="@color/white" />
</FrameLayout>
